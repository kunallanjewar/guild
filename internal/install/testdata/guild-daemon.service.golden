# guild daemon systemd user unit. Generated by 'guild daemon install';
# re-run that command after moving the guild binary, or remove with
# 'guild daemon uninstall'.
#
# No StandardOutput/StandardError overrides on purpose: the daemon
# writes its own log to ~/.guild/daemon.log.

[Unit]
Description=guild daemon (MCP sessions over a unix socket)

[Service]
ExecStart="/usr/local/bin/guild" daemon run
Restart=on-failure

[Install]
WantedBy=default.target
